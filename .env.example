# Clinical Note Processing API - Environment Configuration
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Replace the placeholder values with your actual configuration
# 3. NEVER commit the .env file to version control
# =============================================================================

# =============================================================================
# GROQ API CONFIGURATION (REQUIRED)
# =============================================================================
# Get your free API key from: https://console.groq.com/keys
# Sign up is free and you get rate limits suitable for development/testing
GROQ_API_KEY=your_groq_api_key_here

# Model selection - recommended for production use
# Options:
#   - llama-3.1-70b-versatile (Best accuracy, recommended for healthcare)
#   - mixtral-8x7b-32768 (Fast, good for high-volume)
#   - gemma2-9b-it (Fastest, good for simple queries)
GROQ_MODEL=llama-3.1-70b-versatile

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Server host (0.0.0.0 allows external connections, 127.0.0.1 for localhost only)
APP_HOST=0.0.0.0

# Server port
APP_PORT=8000

# =============================================================================
# LLM CONFIGURATION (OPTIONAL - Defaults are optimized for healthcare)
# =============================================================================
# Temperature: Controls output randomness
# - 0 = Deterministic (RECOMMENDED for healthcare accuracy)
# - 0.3-0.7 = Balanced
# - 1.0 = Creative (NOT recommended for medical data)
LLM_TEMPERATURE=0

# Maximum tokens for entity extraction
# Higher values = more detailed extraction but higher cost
# Range: 500-2000, Recommended: 1000
LLM_MAX_TOKENS_EXTRACT=1000

# Maximum tokens for Q&A responses
# Lower values = more concise answers
# Range: 100-500, Recommended: 300
LLM_MAX_TOKENS_QUERY=300

# =============================================================================
# PRODUCTION NOTES
# =============================================================================
# For production deployments:
# 1. Use environment-specific .env files (.env.production, .env.staging)
# 2. Consider using secrets management (AWS Secrets Manager, Azure Key Vault)
# 3. Rotate API keys regularly
# 4. Monitor API usage and costs
# 5. Ensure GROQ has a BAA (Business Associate Agreement) for HIPAA compliance

